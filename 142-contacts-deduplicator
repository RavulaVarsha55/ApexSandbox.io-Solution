public static List<Contact> ContactDeduplicator(List<Contact> contacts) {
    //code here
    Set<String> emailList= new Set<String>();
    List<Contact> conList= new List<Contact>();
    if(contacts.isEmpty()){
        return null;
    }
    for(Contact c:contacts){
        
        if(!emailList.contains(c.Email)){
            conList.add(c);
        }
    }
    return conList;
}