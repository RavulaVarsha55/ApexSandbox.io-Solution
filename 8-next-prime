public Integer nextPrime(Integer num) {
   Integer candidate = num + 1;
        
        // Keep checking numbers until a prime is found
        while (true) {
            if (isPrime(candidate)) {
                return candidate;
            }
            candidate++;
        }
}
public Boolean isPrime(Integer n) {
        // Prime numbers must be greater than 1
        if (n <= 1) {
            return false;
        }
        
        // Loop from 2 to n-1
        for (Integer i = 2; i < n; i++) {
            // If divisible evenly, not prime
            if (Math.mod(n, i) == 0) {
                return false;
            }
        }
        
        return true;
    }