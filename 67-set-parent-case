public void linkParent(Case c1, Case c2) {
    //code here
    if((c1.contactId!=null && c2.contactId!=null) && c1.contactId==c2.contactId){
        if(c1.CreatedDate<c2.CreatedDate){
            c2.parentId=c1.Id;
        }
        else{
            if(c2.CreatedDate<c1.CreatedDate){
            c1.parentId=c2.Id;
        }
        }
    }
}